{
  "title": "manager",
  "uid": "early-bird-manager",
  "tags": ["early-bird", "service:manager"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      },
      {
        "name": "caller",
        "type": "query",
        "label": "caller",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": { "query": "label_values(caller)", "refId": "caller" },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "DAO commit rate (booking.dao.commit)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Counter booking_dao_commit_total — DRIVERS/s (one increment per driver outcome), split by result (committed/duplicate/rejected) and caller. Note the paired latency panel is per CTE, not per driver.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result, caller) (rate(booking_dao_commit_total{caller=~\"$caller\"}[1m]))",
          "legendFormat": "{{caller}} / {{result}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "DAO commit latency P99 (booking.dao.commit.latency)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Timer booking_dao_commit_latency_seconds, percentile P99 (publishPercentiles(0.99)).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "booking_dao_commit_latency_seconds{quantile=\"0.99\", caller=~\"$caller\"}",
          "legendFormat": "{{caller}} p99"
        }
      ]
    },
    {
      "id": 3,
      "title": "Consumer handle rate (booking.consumer.handle)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Counter booking_consumer_handle_total, tách theo result (committed/duplicate/rejected/error/circuit_open). circuit_open = PG circuit breaker OPEN, batch fast-fail không chạm PG.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result, caller) (rate(booking_consumer_handle_total{caller=~\"$caller\"}[1m]))",
          "legendFormat": "{{caller}} / {{result}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Redis gate release rate (booking.consumer.gate_release)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Counter booking_consumer_gate_release_total, tách theo result (ok/error). Tăng khi PG settle thất bại và manager rollback claimed_set trên Redis cho từng driver.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result, caller) (rate(booking_consumer_gate_release_total{caller=~\"$caller\"}[1m]))",
          "legendFormat": "{{caller}} / {{result}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Driver notify rate (booking.consumer.notify)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Counter booking_consumer_notify_total, tách theo result (confirmed/failed). Tăng mỗi khi manager xác định outcome cuối cho 1 driver (chưa push thật tới app, TODO MQTT/WS).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result, caller) (rate(booking_consumer_notify_total{caller=~\"$caller\"}[1m]))",
          "legendFormat": "{{caller}} / {{result}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "PG liveness probe rate (booking.dao.ping)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Counter booking_dao_ping_total, tách theo result (ok/error). PgHealthProbe ping SELECT 1 theo timer khi circuit breaker OPEN để phát hiện PG hồi phục độc lập traffic; ok → breaker đóng → server nhận request lại.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result, caller) (rate(booking_dao_ping_total{caller=~\"$caller\"}[1m]))",
          "legendFormat": "{{caller}} / {{result}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "PG liveness probe latency P99 (booking.dao.ping.latency)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Timer booking_dao_ping_latency_seconds, percentile P99 (publishPercentiles(0.99)).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "booking_dao_ping_latency_seconds{quantile=\"0.99\", caller=~\"$caller\"}",
          "legendFormat": "{{caller}} p99"
        }
      ]
    }
  ]
}
