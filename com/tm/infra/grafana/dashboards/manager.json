{
  "title": "manager",
  "uid": "early-bird-manager",
  "tags": ["early-bird", "service:manager"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "DAO commit rate (booking.dao.commit)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Counter booking_dao_commit_total, tách theo result (committed/duplicate/rejected).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate(booking_dao_commit_total[1m]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "DAO commit latency P99 (booking.dao.commit.latency)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Timer booking_dao_commit_latency_seconds, percentile P99 (publishPercentiles(0.99)).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "booking_dao_commit_latency_seconds{quantile=\"0.99\"}",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 3,
      "title": "Consumer handle rate (booking.consumer.handle)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Counter booking_consumer_handle_total, tách theo result (committed/duplicate/rejected/error).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate(booking_consumer_handle_total[1m]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Redis gate release rate (booking.consumer.gate_release)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Counter booking_consumer_gate_release_total, tách theo result (ok/error). Tăng khi PG settle thất bại và manager rollback claimed_set trên Redis cho từng driver.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate(booking_consumer_gate_release_total[1m]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Driver notify rate (booking.consumer.notify)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Counter booking_consumer_notify_total, tách theo result (confirmed/failed). Tăng mỗi khi manager xác định outcome cuối cho 1 driver (chưa push thật tới app, TODO MQTT/WS).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate(booking_consumer_notify_total[1m]))",
          "legendFormat": "{{result}}"
        }
      ]
    }
  ]
}
