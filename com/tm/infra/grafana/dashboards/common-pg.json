{
  "title": "common — PG Claim Store",
  "uid": "early-bird-common-pg",
  "tags": ["early-bird", "common:pg"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      },
      {
        "name": "caller",
        "type": "query",
        "label": "caller",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": { "query": "label_values(caller)", "refId": "caller" },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "PG settle rate — DRIVERS/s (booking.pg.settle)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Counter booking_pg_settle_total — DRIVER traffic: one increment per claim/event (incl. intra-batch duplicates), split by result (committed/duplicate/rejected/error) and caller (scenario). This is the real settled-claims throughput. Compare with the per-CTE panel: drivers/s ÷ CTE/s = effective sub-batch size.",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "committed" }, "properties": [{ "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "duplicate" }, "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "rejected"  }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "error"     }, "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result, caller) (rate(booking_pg_settle_total{caller=~\"$caller\"}[1m]))",
          "legendFormat": "{{caller}} / {{result}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "PG settle rate — CTE/s (booking.pg.settle.batch)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Counter booking_pg_settle_batch_total — CTE traffic: one increment per settleOpportunity() call = one bulk CTE = one SQL round-trip, split by ok/error and caller (scenario). drivers/s (per-driver panel) ÷ CTE/s (this panel) = effective sub-batch size.",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "ok"    }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "fixedColor": "red",   "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result, caller) (rate(booking_pg_settle_batch_total{caller=~\"$caller\"}[1m]))",
          "legendFormat": "{{caller}} / {{result}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "PG settle latency P99 — per CTE (booking.pg.settle.latency)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Timer booking_pg_settle_latency_seconds, P99 — measured PER CTE (one sample per settleOpportunity() call), not per driver: pure CTE execution time in PG, split by caller (scenario). Reference: <50ms OK, >200ms investigate.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "booking_pg_settle_latency_seconds{quantile=\"0.99\", caller=~\"$caller\"}",
          "legendFormat": "{{caller}} P99 / CTE"
        }
      ]
    }
  ]
}
