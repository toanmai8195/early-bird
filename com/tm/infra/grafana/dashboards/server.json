{
  "title": "server",
  "uid": "early-bird-server",
  "tags": ["early-bird", "service:server"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      { "name": "datasource", "type": "datasource", "query": "prometheus", "current": {} }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Claim API rate (booking.api.claim)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Counter booking_api_claim_total, tách theo result (ok/dup/full/closed/down/throttled/error). down = PG health kill switch bật (manager CB open) → gate shed claim với 503.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate(booking_api_claim_total[1m]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Claim API latency P99 (booking.api.claim.latency)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Timer booking_api_claim_latency_seconds, percentile P99 (publishPercentiles(0.99)).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "booking_api_claim_latency_seconds{quantile=\"0.99\"}",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 3,
      "title": "Opportunity CRUD API rate (booking.api.opportunity)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Counter booking_api_opportunity_total, tách theo result (created/found/updated/deleted/not_found/error).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate(booking_api_opportunity_total[1m]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Opportunity CRUD API latency P99 (booking.api.opportunity.latency)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Timer booking_api_opportunity_latency_seconds, percentile P99 (publishPercentiles(0.99)).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "booking_api_opportunity_latency_seconds{quantile=\"0.99\"}",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 5,
      "title": "Opportunity DAO rate (booking.dao.opportunity)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Counter booking_dao_opportunity_total, tách theo result (create_ok/create_error/get_ok/.../delete_error).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate(booking_dao_opportunity_total[1m]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Opportunity DAO latency P99 (booking.dao.opportunity.latency)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Timer booking_dao_opportunity_latency_seconds, percentile P99 (publishPercentiles(0.99)).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "booking_dao_opportunity_latency_seconds{quantile=\"0.99\"}",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 7,
      "title": "Reconciliation DAO rate (booking.dao.reconciliation)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Counter booking_dao_reconciliation_total, tách theo result (list_open_ok/.../claimed_drivers_error).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate(booking_dao_reconciliation_total[1m]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Reconciliation DAO latency P99 (booking.dao.reconciliation.latency)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Timer booking_dao_reconciliation_latency_seconds, percentile P99 (publishPercentiles(0.99)).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "booking_dao_reconciliation_latency_seconds{quantile=\"0.99\"}",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 9,
      "title": "Redis warmup rate (booking.redis.warmup)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Counter booking_redis_warmup_total, tách theo result (skipped/restored/error). skipped = heartbeat key vẫn còn (Redis chưa mất data); restored = heartbeat mất, đã rebuild opp_meta/claimed_set từ PG cho mọi opportunity đang mở.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate(booking_redis_warmup_total[1m]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "Redis warmup latency P99 (booking.redis.warmup.latency)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Timer booking_redis_warmup_latency_seconds, percentile P99 (publishPercentiles(0.99)).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "booking_redis_warmup_latency_seconds{quantile=\"0.99\"}",
          "legendFormat": "p99"
        }
      ]
    }
  ]
}
