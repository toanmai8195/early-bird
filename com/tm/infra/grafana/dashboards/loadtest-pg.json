{
  "title": "Loadtest \u2014 PG Claim Store",
  "uid": "loadtest-pg",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "tags": [
    "loadtest"
  ],
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Ramp \u2014 batch \u00d7 traffic sweep",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 101,
      "type": "timeseries",
      "title": "Traffic \u2014 target rate (loadtest_pg_ramp_rate)",
      "description": "Offered load for the current step: CTE/s the ticker dispatches. Sweeps the rates in --ramp-rates for each batch size.",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "lineInterpolation": "stepAfter"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "loadtest_pg_ramp_rate",
          "legendFormat": "target CTE/s"
        }
      ]
    },
    {
      "id": 102,
      "type": "timeseries",
      "title": "Batch size \u2014 drivers/CTE (loadtest_pg_ramp_batch)",
      "description": "Current batch size (drivers settled per CTE). The outer sweep steps it through --ramp-batch-sizes; each value runs all traffic steps.",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "custom": {
            "lineWidth": 2,
            "lineInterpolation": "stepAfter"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "loadtest_pg_ramp_batch",
          "legendFormat": "drivers/CTE"
        }
      ]
    },
    {
      "id": 103,
      "type": "timeseries",
      "title": "CTE traffic \u2014 CTE/s by batch (loadtest_pg_ramp_cte_total)",
      "description": "Bulk-settle CTEs per second (one per settleRamp call = one FOR UPDATE round-trip), split by batch size. On a hot row this is what serialises.",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum by (batch) (rate(loadtest_pg_ramp_cte_total{batch=~\"$batch\"}[30s]))",
          "legendFormat": "batch={{batch}}"
        }
      ]
    },
    {
      "id": 104,
      "type": "timeseries",
      "title": "Driver traffic \u2014 drivers/s by batch (loadtest_pg_ramp_claims_total)",
      "description": "Drivers settled per second (= CTE/s \u00d7 batch), split by batch size. Shows how a bigger batch lifts driver throughput on the same hot row.",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum by (batch) (rate(loadtest_pg_ramp_claims_total{batch=~\"$batch\"}[30s]))",
          "legendFormat": "batch={{batch}}"
        }
      ]
    },
    {
      "id": 105,
      "type": "timeseries",
      "title": "CTE latency by batch \u2014 p50 / p99 / max (loadtest_pg_ramp_latency)",
      "description": "Per-CTE settle latency by batch size. Watch p99 grow as batch grows: sub-linear is the win (round-trip amortised), super-linear = CTE planning on a large VALUES list dominating.",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 24,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*p50.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*p99.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*max.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "loadtest_pg_ramp_latency_p50_seconds{batch=~\"$batch\"}",
          "legendFormat": "batch={{batch}} p50"
        },
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "loadtest_pg_ramp_latency_p99_seconds{batch=~\"$batch\"}",
          "legendFormat": "batch={{batch}} p99"
        },
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "loadtest_pg_ramp_latency_max_seconds{batch=~\"$batch\"}",
          "legendFormat": "batch={{batch}} max"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "batch",
        "label": "Batch size",
        "type": "query",
        "datasource": {
          "type": "prometheus"
        },
        "query": {
          "query": "label_values(loadtest_pg_ramp_cte_total, batch)",
          "refId": "batch"
        },
        "refresh": 2,
        "sort": 3,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ],
          "selected": true
        }
      }
    ]
  }
}
